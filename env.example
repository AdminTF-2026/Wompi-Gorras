# ══════════════════════════════════════════════════════════════
#  VARIABLES DE ENTORNO - Backend Wompi Gorras Colombia
#  Copia este archivo como .env y completa los valores reales.
#  NUNCA subas el .env a GitHub (ya está en .gitignore).
# ══════════════════════════════════════════════════════════════

# Puerto del servidor (Railway lo asigna automáticamente, no lo cambies en producción)
PORT=3000

# ─── WOMPI ──────────────────────────────────────────────────────────────────────
# Clave PÚBLICA de Wompi → empieza con pub_test_ (pruebas) o pub_prod_ (producción)
# Se usa en el frontend (index.html), NO aquí. La dejamos documentada para referencia.
# WOMPI_PUBLIC_KEY=pub_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Clave PRIVADA de Wompi → empieza con prv_test_ (pruebas) o prv_prod_ (producción)
# ⚠️ ESTA ES SECRETA. Solo va aquí, nunca en el frontend.
WOMPI_PRIVATE_KEY=prv_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Secret de INTEGRIDAD de Wompi → lo encuentras en tu panel Wompi → Desarrolladores → Llaves
# Es diferente a la clave privada. Empieza con test_integrity_ o prod_integrity_
WOMPI_INTEGRITY_SECRET=test_integrity_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── FRONTEND ───────────────────────────────────────────────────────────────────
# URL de tu landing page (para el CORS). Ejemplos:
# https://pruebas.multiproyecto.com
# https://tu-dominio.com
# Deja * durante desarrollo para permitir cualquier origen
FRONTEND_URL=https://pruebas.multiproyecto.com
